+fn status_line_command_refresh_interval(config: &TuiStatusLineCommand) -> Duration {
+    if config.refresh_interval_ms == 0 {
+        STATUS_LINE_COMMAND_DEFAULT_REFRESH_INTERVAL
+    } else {
+        Duration::from_millis(config.refresh_interval_ms)
+            .max(STATUS_LINE_COMMAND_MIN_REFRESH_INTERVAL)
+    }
+}
+
+fn status_line_command_timeout(config: &TuiStatusLineCommand) -> Duration {
+    if config.timeout_ms == 0 {
+        STATUS_LINE_COMMAND_DEFAULT_TIMEOUT
+    } else {
+        Duration::from_millis(config.timeout_ms)
+    }
+}
+
+fn status_line_command_output_lines(output: &str) -> Option<Vec<Line<'static>>> {
+    let output = output.trim_end_matches(['\r', '\n']);
+    if output.trim().is_empty() {
+        return None;
+    }
+
+    let text = codex_ansi_escape::ansi_escape(output);
+    let lines = text
+        .lines
+        .into_iter()
+        .take(STATUS_LINE_COMMAND_MAX_LINES)
+        .collect::<Vec<_>>();
+    (!lines.is_empty()).then_some(lines)
+}
+
+async fn run_status_line_command(
+    config: TuiStatusLineCommand,
+    cwd: PathBuf,
+    payload: String,
+) -> Option<String> {
+    let timeout_duration = status_line_command_timeout(&config);
+    let mut command = status_line_shell_command(&config.command);
+    command
+        .current_dir(cwd)
+        .env("CODEX_STATUS_LINE", "1")
+        .stdin(Stdio::piped())
+        .stdout(Stdio::piped())
+        .stderr(Stdio::null())
+        .kill_on_drop(true);
+
+    let mut child = match command.spawn() {
+        Ok(child) => child,
+        Err(err) => {
+            tracing::debug!(error = %err, "failed to spawn status-line command");
+            return None;
+        }
+    };
+
+    if let Some(mut stdin) = child.stdin.take() {
+        tokio::spawn(async move {
+            let _ = stdin.write_all(payload.as_bytes()).await;
+        });
+    }
+
+    let output = match timeout(timeout_duration, child.wait_with_output()).await {
+        Ok(Ok(output)) => output,
+        Ok(Err(err)) => {
+            tracing::debug!(error = %err, "failed to wait for status-line command");
+            return None;
+        }
+        Err(_) => {
+            tracing::debug!("status-line command timed out");
+            return None;
+        }
+    };
+
+    if !output.status.success() {
+        tracing::debug!(
+            status = ?output.status.code(),
+            "status-line command exited unsuccessfully"
+        );
+        return None;
+    }
+
+    Some(
+        String::from_utf8_lossy(&output.stdout)
+            .chars()
+            .take(STATUS_LINE_COMMAND_MAX_OUTPUT_CHARS)
+            .collect(),
+    )
+}
+
+fn status_line_shell_command(command_text: &str) -> Command {
+    #[cfg(target_os = "windows")]
+    {
+        let mut command = Command::new("cmd");
+        command.arg("/C").arg(command_text);
+        command
+    }
+
+    #[cfg(not(target_os = "windows"))]
+    {
+        let mut command = Command::new("sh");
+        command.arg("-c").arg(command_text);
+        command
+    }
+}
